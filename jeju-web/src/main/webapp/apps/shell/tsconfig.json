{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@runtime/*": ["src/runtime/*"],
      "@front-fab/*": ["../../components/react/ui/FAB/*"],
      "@front-components/*": ["../../components/react/*"]
    }
  },
  "include": [
    "src",
    "../../components/react/**/*.ts",
    "../../components/react/**/*.tsx",
    "../../components/react/**/*.d.ts"
  ]
}
